@model CrmProject.Entity.Entities.Customer
@{
    ViewData["Title"] = "Müşteri Güncelle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="max-w-4xl mx-auto">
    <div class="mb-8">
        <h1 class="text-2xl font-extrabold text-[#001f48]">Müşteri Bilgilerini Düzenle</h1>
    </div>

    <div class="bg-white rounded-3xl p-8 border border-slate-200 shadow-sm">
        <form action="/Customer/UpdateCustomer" method="post" class="space-y-6">
            <input type="hidden" asp-for="Id" />
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 font-inter">
                <div class="md:col-span-2">
                    <label class="block text-sm font-bold text-slate-700 mb-2">Firma / Şahıs Adı</label>
                    <input type="text" asp-for="CustomerName" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3" required />
                </div>

                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Yetkili Kişi</label>
                    <input type="text" asp-for="ContactPerson" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3" required />
                </div>

                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">E-Posta</label>
                    <input type="email" asp-for="Email" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3" required />
                </div>

                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Telefon</label>
                    <input type="text" asp-for="Phone" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3" required />
                </div>
                
                <div class="flex items-center mt-8">
                    <label class="flex items-center gap-3 cursor-pointer">
                        <input type="checkbox" asp-for="Status" class="w-5 h-5 rounded border-slate-300 text-[#0058be] focus:ring-[#0058be] transition-all" />
                        <span class="text-sm font-semibold text-slate-700">Aktif</span>
                    </label>
                </div>

                <div class="md:col-span-2">
                    <label class="block text-sm font-bold text-slate-700 mb-2">Açık Adres</label>
                    <textarea asp-for="Address" rows="3" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 resize-none" required></textarea>
                </div>
            </div>

            <div class="pt-6 border-t border-slate-100 flex justify-end gap-3">
                <a href="/Customer/Index" class="px-6 py-3 text-slate-600 font-bold bg-slate-50 rounded-xl">İptal</a>
                <button type="submit" class="px-8 py-3 bg-[#00346f] text-white font-bold rounded-xl shadow-md">Güncellemeleri Kaydet</button>
            </div>
        </form>
    </div>
</div>