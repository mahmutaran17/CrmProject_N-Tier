@model List<CrmProject.Entity.Entities.Expense>
@{
    ViewData["Title"] = "Giderler";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="flex justify-between items-center mb-8">
    <h1 class="text-2xl font-bold text-blue-900">Proje Giderleri</h1>
    <a href="/Expense/Create" class="bg-blue-900 text-white px-5 py-2.5 rounded-xl text-sm font-semibold">Yeni Gider</a>
</div>

<div class="bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden">
    <table class="w-full text-left">
        <thead class="bg-slate-50 border-b border-slate-200 text-slate-500 text-xs uppercase">
            <tr>
                <th class="p-4 font-semibold">Proje</th>
                <th class="p-4 font-semibold">Kategori</th>
                <th class="p-4 font-semibold">Tarih</th>
                <th class="p-4 font-semibold">Tutar</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 text-sm text-slate-700">
            @foreach (var item in Model)
            {
                <tr class="hover:bg-slate-50">
                    <td class="p-4 font-bold">@(item.Project != null ? item.Project.ProjectName : "-")</td>
                    <td class="p-4">@item.Category</td>
                    <td class="p-4">@item.Date.ToString("dd.MM.yyyy")</td>
                    <td class="p-4 font-bold text-red-600">-@item.Amount.ToString("N2") ₺</td>
                </tr>
            }
        </tbody>
    </table>
</div>