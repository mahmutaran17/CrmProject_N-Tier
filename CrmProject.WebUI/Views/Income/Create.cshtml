@model CrmProject.Entity.Entities.Income
@{
    ViewData["Title"] = "Yeni Gelir Ekle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="mb-8">
    <h1 class="text-2xl font-bold text-blue-900">Yeni Gelir (Tahsilat) Ekle</h1>
</div>

<div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8 max-w-4xl">
    <form method="post" action="/Income/Create">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            
            <div class="col-span-1 md:col-span-2">
                <label class="block text-sm font-semibold text-slate-700 mb-2">İlgili Proje <span class="text-red-500">*</span></label>
                <select asp-for="ProjectId" asp-items="ViewBag.Projects" class="w-full rounded-xl border-slate-300 py-2.5 text-sm" required>
                    <option value="">-- Proje Seçiniz --</option>
                </select>
            </div>

            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Gelir Kaynağı <span class="text-red-500">*</span></label>
                <input type="text" asp-for="Source" class="w-full rounded-xl border-slate-300 py-2.5 text-sm" placeholder="Örn: Hak ediş, Peşinat, Ek Geliştirme..." required />
            </div>

            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Tutar (₺) <span class="text-red-500">*</span></label>
                <input type="number" step="0.01" asp-for="Amount" class="w-full rounded-xl border-slate-300 py-2.5 text-sm" required />
            </div>

            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Tarih <span class="text-red-500">*</span></label>
                <input type="date" asp-for="Date" class="w-full rounded-xl border-slate-300 py-2.5 text-sm" required />
            </div>

            <div class="col-span-1 md:col-span-2">
                <label class="block text-sm font-semibold text-slate-700 mb-2">Açıklama</label>
                <textarea asp-for="Description" rows="3" class="w-full rounded-xl border-slate-300 py-2.5 text-sm"></textarea>
            </div>

        </div>

        <div class="mt-8 flex justify-end gap-3 pt-6 border-t border-slate-100">
            <a href="/Income/Index" class="px-5 py-2.5 text-sm font-semibold text-slate-600 bg-slate-100 rounded-xl">Vazgeç</a>
            <button type="submit" class="px-5 py-2.5 text-sm font-semibold text-white bg-blue-900 rounded-xl">Kaydet</button>
        </div>
    </form>
</div>