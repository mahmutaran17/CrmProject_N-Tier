@model IEnumerable<CrmProject.Entity.Entities.User>
@{
    ViewData["Title"] = "Personel Listesi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="flex justify-between items-center mb-8">
    <div>
        <h1 class="text-2xl font-extrabold text-blue-900 tracking-tight">Personel Yönetimi</h1>
        <p class="text-sm text-slate-500 mt-1">Sisteme kayıtlı aktif ekip üyelerini yönetin.</p>
    </div>
    <a href="/User/AddUser" class="bg-blue-900 text-white px-5 py-2.5 rounded-xl text-sm font-semibold flex items-center gap-2 hover:bg-blue-800 transition-colors shadow-sm">
        <span class="material-symbols-outlined text-[20px]">person_add</span> Yeni Personel
    </a>
</div>

<div class="bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden">
    <table class="w-full text-left">
        <thead class="bg-slate-50 border-b border-slate-200 text-slate-500 text-xs uppercase font-bold">
            <tr>
                <th class="p-4">Ad Soyad</th>
                <th class="p-4">E-Posta</th>
                <th class="p-4">Kayıt Tarihi</th>
                <th class="p-4 text-right">İşlemler</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 text-sm text-slate-700">
            @foreach (var item in Model)
            {
                <tr class="hover:bg-slate-50 transition-colors">
                    <td class="p-4 font-bold text-blue-900 flex items-center gap-3">
                        <div class="w-8 h-8 rounded-full bg-blue-100 text-blue-800 flex items-center justify-center text-xs">
                            @(item.FirstName?.Substring(0, 1).ToUpper())@(item.LastName?.Substring(0, 1).ToUpper())
                        </div>
                        @item.FirstName @item.LastName
                    </td>
                    <td class="p-4 text-slate-500">@item.Email</td>
                    <td class="p-4 text-slate-500">@item.RegistrationDate.ToString("dd.MM.yyyy")</td>
                    <td class="p-4">
                        <div class="flex items-center justify-end gap-3">
                            <a href="/User/UpdateUser/@item.Id" class="text-yellow-600 hover:text-yellow-700 font-bold text-xs flex items-center gap-1">
                                <span class="material-symbols-outlined text-[16px]">edit</span> Düzenle
                            </a>
                            <a href="/User/DeleteUser/@item.Id" onclick="return confirm('Bu personeli silmek istediğinize emin misiniz?');" class="text-red-600 hover:text-red-700 font-bold text-xs flex items-center gap-1">
                                <span class="material-symbols-outlined text-[16px]">delete</span> Sil
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>