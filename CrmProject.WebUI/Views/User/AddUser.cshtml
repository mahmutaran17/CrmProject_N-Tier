@model CrmProject.Entity.Entities.User
@{
    ViewData["Title"] = "Yeni Personel Ekle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="mb-8">
    <h1 class="text-2xl font-extrabold text-blue-900 tracking-tight">Yeni Personel Ekle</h1>
    <p class="text-slate-500 text-sm mt-1">Sisteme giriş yapabilecek yeni bir ekip üyesi tanımlayın.</p>
</div>

<div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8 max-w-3xl">
    <form method="post" action="/User/AddUser">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            
            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">Ad <span class="text-red-500">*</span></label>
                <input type="text" asp-for="FirstName" class="w-full rounded-xl border-slate-300 px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-100 outline-none transition-all" required />
            </div>

            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">Soyad <span class="text-red-500">*</span></label>
                <input type="text" asp-for="LastName" class="w-full rounded-xl border-slate-300 px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-100 outline-none transition-all" required />
            </div>

            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">E-Posta Adresi <span class="text-red-500">*</span></label>
                <input type="email" asp-for="Email" class="w-full rounded-xl border-slate-300 px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-100 outline-none transition-all" required />
            </div>

            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">Giriş Şifresi <span class="text-red-500">*</span></label>
                <input type="text" asp-for="PasswordHash" class="w-full rounded-xl border-slate-300 px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-100 outline-none transition-all" required />
                <span class="text-[11px] text-slate-400 mt-1 block">Personel sisteme bu şifre ile giriş yapacaktır.</span>
            </div>

            <div class="col-span-1 md:col-span-2">
                <label class="block text-sm font-bold text-slate-700 mb-2">Sistem Rolü <span class="text-red-500">*</span></label>
                <select asp-for="RoleId" asp-items="ViewBag.Roles" class="w-full rounded-xl border-slate-300 px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-100 outline-none transition-all" required>
                    <option value="">-- Rol Seçiniz --</option>
                </select>
            </div>

        </div>

        <div class="mt-8 flex justify-end gap-3 pt-6 border-t border-slate-100">
            <a href="/User/Index" class="px-6 py-3 text-sm font-bold text-slate-600 bg-slate-100 rounded-xl hover:bg-slate-200 transition-colors">Vazgeç</a>
            <button type="submit" class="px-6 py-3 text-sm font-bold text-white bg-blue-900 rounded-xl hover:bg-blue-800 transition-colors shadow-md">
                Personeli Kaydet
            </button>
        </div>
    </form>
</div>