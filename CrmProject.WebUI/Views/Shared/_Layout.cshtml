<!DOCTYPE html>
<html class="light" lang="tr">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - Executive Ledger</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#00346f",
                        "surface": "#f8f9fa",
                        "on-surface": "#191c1d",
                        "surface-container-highest": "#e1e3e4",
                        // ... (Diğer renkler uzun sürmesin diye kısalttım, Tailwind ana renkleri çalışacaktır)
                    },
                    fontFamily: { "headline": ["Manrope"], "body": ["Inter"] }
                }
            }
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .executive-gradient {
            background: linear-gradient(135deg, #00346f 0%, #004a99 100%);
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8f9fa;
            min-height: max(884px, 100dvh);
        }

        h1, h2, h3, .headline {
            font-family: 'Manrope', sans-serif;
        }
    </style>
</head>
<body class="bg-surface text-on-surface min-h-screen pb-24 md:pb-0 md:pt-16">

    <header class="fixed top-0 w-full z-50 bg-white/80 backdrop-blur-md border-b shadow-sm flex justify-between items-center px-6 py-3">
        <div class="flex items-center gap-3">
            <span class="font-manrope font-extrabold text-blue-900 text-xl tracking-tight">Executive Ledger</span>
        </div>
    
        <div class="hidden md:flex items-center gap-8">
            <nav class="flex gap-6">
                <a class="text-slate-500 hover:text-blue-700 transition-colors font-inter font-semibold text-sm" href="/">Ana Sayfa</a>
                <a class="text-slate-500 hover:text-blue-700 transition-colors font-inter font-semibold text-sm" href="/Project/Index">Projeler</a>
                <a class="text-slate-500 hover:text-blue-700 transition-colors font-inter font-semibold text-sm" href="/AppTask/Index">Görevler</a>
                <a class="text-slate-500 hover:text-blue-700 transition-colors font-inter font-semibold text-sm" href="/User/Index">Personeller</a>
            </nav>
        </div>

        <div class="flex items-center gap-4">
            @if (User.Identity.IsAuthenticated)
            {
                <div class="flex items-center gap-3 pr-4 border-r border-slate-200">
                    <div class="text-right hidden sm:block">
                        <p class="text-xs font-bold text-blue-900 leading-none">@User.Identity.Name</p>
                        <p class="text-[10px] text-slate-500 font-medium">Aktif Kullanıcı</p>
                    </div>
                    <a href="/Login/Logout" class="material-symbols-outlined text-slate-400 hover:text-red-500 transition-colors" title="Çıkış Yap">logout</a>
                </div>
            }
            else
            {
                <a href="/Login/Index" class="text-sm font-bold text-blue-900 hover:underline">Giriş Yap</a>
            }

            <button class="material-symbols-outlined text-slate-500 hover:bg-slate-100 p-2 rounded-xl">notifications</button>
        
            <div class="w-8 h-8 rounded-full overflow-hidden bg-gray-200 border border-slate-200">
                <img class="w-full h-full object-cover" src="https://ui-avatars.com/api/?name=@(User.Identity.Name ?? "Misafir")&background=00346f&color=fff" />
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-6 pt-24 pb-12">
        @RenderBody()
    </main>

    <nav class="md:hidden fixed bottom-0 left-0 w-full bg-white/90 backdrop-blur-lg flex justify-around items-center px-4 pb-6 pt-2 z-50 rounded-t-2xl shadow-lg">
        <a class="flex flex-col items-center justify-center text-slate-400 px-4 py-1" href="/">
            <span class="material-symbols-outlined">home</span>
            <span class="text-[11px] font-semibold uppercase tracking-wider mt-1">Ana Sayfa</span>
        </a>
        <a class="flex flex-col items-center justify-center text-blue-900 bg-blue-50 rounded-xl px-4 py-1" href="/Project/Index">
            <span class="material-symbols-outlined">assignment</span>
            <span class="text-[11px] font-semibold uppercase tracking-wider mt-1">Projeler</span>
        </a>
    </nav>

</body>
</html>