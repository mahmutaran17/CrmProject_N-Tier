@using System.Security.Claims
@inject CrmProject.Business.Abstract.INotificationService NotificationService
@inject CrmProject.Business.Abstract.IUserService UserService

<!DOCTYPE html>
<html class="light" lang="tr">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - Executive Ledger</title>
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#001f48", "secondary": "#0058be", "surface": "#f9f9fe", "on-surface": "#1a1b20",
                        "surface-container-lowest": "#ffffff", "surface-container-low": "#f4f3f9",
                        "outline-variant": "#c3c6d1", "primary-container": "#00346f",
                    },
                    fontFamily: { "headline": ["Manrope"], "body": ["Inter"], }
                }
            }
        }
    </script>
    <style>
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        body { -webkit-tap-highlight-color: transparent; }
    </style>
</head>
<body class="bg-surface font-body text-on-surface min-h-screen flex flex-col">

    <header class="w-full top-0 sticky z-40 bg-surface/90 backdrop-blur-md border-b border-outline-variant/20 flex justify-between items-center px-6 py-4">
        <div class="flex items-center gap-8">
            <h1 class="text-2xl font-bold text-primary tracking-tighter font-headline">Executive Ledger</h1>
            <nav class="hidden md:flex gap-6">
                <a class="text-slate-600 hover:text-secondary font-semibold text-sm transition-colors" href="/Home/Index">Ana Sayfa</a>
                <a class="text-slate-600 hover:text-secondary font-semibold text-sm transition-colors" href="/Customer/Index">Müşteriler</a>
                <a class="text-slate-600 hover:text-secondary font-semibold text-sm transition-colors" href="/Project/Index">Projeler</a>
                <a class="text-slate-600 hover:text-secondary font-semibold text-sm transition-colors" href="/AppTask/Index">Görevler</a>
                <a class="text-slate-600 hover:text-secondary font-semibold text-sm transition-colors" asp-controller="TaskLog" asp-action="Index">Görev Günlükleri</a>
    
                @if (User.IsInRole("Admin"))
                {
                    <a class="text-slate-600 hover:text-secondary font-semibold text-sm transition-colors" href="/Income/Index">Gelirler</a>
                    <a class="text-slate-600 hover:text-secondary font-semibold text-sm transition-colors" href="/Expense/Index">Giderler</a>
                    <a class="text-slate-600 hover:text-secondary font-semibold text-sm transition-colors" href="/User/Index">Personeller</a>
                }
            </nav>
        </div>

        <div class="flex items-center gap-5">
            @{
                int unreadNotificationCount = 0;
                List<CrmProject.Entity.Entities.Notification> topNotifications = new List<CrmProject.Entity.Entities.Notification>();
                if (User.Identity.IsAuthenticated)
                {
                    var userIdStr = User.Claims.FirstOrDefault(c => c.Type == "UserId")?.Value;
                    if (!string.IsNullOrEmpty(userIdStr))
                    {
                        int currentUserId = int.Parse(userIdStr);
                        var notifications = await NotificationService.GetWhereAsync(n => n.UserId == currentUserId && !n.IsRead);
                        unreadNotificationCount = notifications.Count();
                        topNotifications = notifications.OrderByDescending(n => n.CreatedAt).Take(5).ToList();
                    }
                }
            }

            <div class="relative group" id="notification-container">
                <button id="notification-btn" class="relative text-primary hover:text-secondary transition-colors p-2">
                    <span class="material-symbols-outlined">notifications</span>
                    @if (unreadNotificationCount > 0)
                    {
                        <span class="absolute top-1 right-1 flex h-3 w-3 items-center justify-center rounded-full bg-red-500 text-[8px] text-white font-black ring-2 ring-surface">@unreadNotificationCount</span>
                    }
                </button>

                <div id="notification-dropdown" class="hidden absolute right-0 mt-2 w-80 bg-white rounded-xl shadow-xl border border-slate-100 z-50 overflow-hidden">
                    <div class="p-4 border-b border-slate-50 flex justify-between items-center bg-slate-50">
                        <span class="font-bold text-slate-700 text-sm">Bildirimler</span>
                        @if (unreadNotificationCount > 0) { <a href="/Notification/MarkAllRead" class="text-[11px] text-secondary font-bold hover:underline">Tümünü Okundu İşaretle</a> }
                    </div>
                    <div class="max-h-80 overflow-y-auto">
                        @if (topNotifications.Any())
                        {
                            foreach (var notif in topNotifications)
                            {
                                <a href="/Notification/ReadAndRedirect/@notif.Id" class="block p-4 border-b border-slate-50 hover:bg-slate-50">
                                    <p class="text-xs text-slate-700 font-semibold">@notif.Message</p>
                                    <span class="text-[10px] text-slate-400">@notif.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                                </a>
                            }
                        }
                        else
                        {
                            <div class="p-6 text-center text-slate-500 text-xs">Yeni bildiriminiz yok.</div>
                        }
                    </div>
                    <div class="p-3 border-t border-slate-50 text-center bg-slate-50">
                        <a href="/Notification/Index" class="text-xs font-bold text-primary hover:underline">Tüm Bildirimleri Gör</a>
                    </div>
                </div>
            </div>

            @if (User.Identity.IsAuthenticated)
            {
                var userIdStrForProfile = User.Claims.FirstOrDefault(c => c.Type == "UserId")?.Value;
                CrmProject.Entity.Entities.User currentUserObj = null;
                if (!string.IsNullOrEmpty(userIdStrForProfile))
                {
                    currentUserObj = await UserService.GetByIdAsync(int.Parse(userIdStrForProfile));
                }

                <div class="flex items-center gap-3 border-l border-outline-variant/30 pl-4 relative group cursor-pointer">
                    <div class="text-right hidden sm:block">
                        <p class="text-sm font-bold text-primary leading-none group-hover:text-secondary transition-colors">@User.Identity.Name</p>
                        <p class="text-[10px] text-slate-400 font-medium">Profil & Ayarlar</p>
                    </div>
                    
                    <div class="w-10 h-10 rounded-full bg-primary-container overflow-hidden ring-2 ring-transparent group-hover:ring-secondary/30 transition-all">
                        @if (currentUserObj != null && !string.IsNullOrEmpty(currentUserObj.ProfileImageUrl))
                        {
                            <img class="w-full h-full object-cover" src="@currentUserObj.ProfileImageUrl" alt="Profil" />
                        }
                        else
                        {
                            <img class="w-full h-full object-cover" src="https://ui-avatars.com/api/?name=@(User.Identity?.Name ?? "User")&background=00346f&color=fff" />
                        }
                    </div>

                    <div class="absolute top-full right-0 mt-3 w-48 bg-white rounded-xl shadow-xl border border-slate-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-50">
                        <a href="/User/MyProfile" class="block px-4 py-3 text-sm font-bold text-slate-700 hover:bg-slate-50 hover:text-[#0058be] border-b border-slate-50 flex items-center gap-2">
                            <span class="material-symbols-outlined text-[18px]">person</span> Profilim
                        </a>
                        <a href="/Login/Logout" class="block px-4 py-3 text-sm font-bold text-red-600 hover:bg-red-50 flex items-center gap-2 rounded-b-xl">
                            <span class="material-symbols-outlined text-[18px]">logout</span> Güvenli Çıkış
                        </a>
                    </div>
                </div>
            }
            else
            {
                <a href="/Login/Index" class="bg-[#00346f] text-white px-6 py-2 rounded-xl text-sm font-bold hover:bg-[#001f48] transition-all">Giriş Yap</a>
            }
        </div>
    </header>

    <main class="flex-grow w-full max-w-7xl mx-auto px-4 md:px-8 py-8 pb-32">
        @RenderBody()
    </main>

    <nav class="fixed bottom-6 w-full z-50 flex justify-center md:hidden">
    <div class="bg-white/90 backdrop-blur-xl border border-outline-variant/20 shadow-xl rounded-2xl w-[95%] flex justify-around items-center py-2 px-1">
        <a class="flex flex-col items-center text-secondary p-2" href="/Home/Index">
            <span class="material-symbols-outlined mb-1">home</span>
            <span class="text-[9px] font-bold uppercase">Ana Sayfa</span>
        </a>
        <a class="flex flex-col items-center text-slate-400 hover:text-secondary p-2" href="/Customer/Index">
            <span class="material-symbols-outlined mb-1">groups</span>
            <span class="text-[9px] font-bold uppercase">Müşteri</span>
        </a>
        <a class="flex flex-col items-center text-slate-400 hover:text-secondary p-2" href="/Project/Index">
            <span class="material-symbols-outlined mb-1">account_tree</span>
            <span class="text-[9px] font-bold uppercase">Proje</span>
        </a>
        <a class="flex flex-col items-center text-slate-400 hover:text-secondary p-2" href="/AppTask/Index">
            <span class="material-symbols-outlined mb-1">task</span>
            <span class="text-[9px] font-bold uppercase">Görev</span>
        </a>
        <a class="flex flex-col items-center text-slate-400 hover:text-secondary p-2" asp-controller="TaskLog" asp-action="Index">
                <span class="material-symbols-outlined mb-1">list_alt</span>
                <span class="text-[9px] font-bold uppercase">Günlükler</span>
        </a>

        @if (User.IsInRole("Admin"))
        {
            <a class="flex flex-col items-center text-slate-400 hover:text-secondary p-2" href="/Income/Index">
                <span class="material-symbols-outlined mb-1">payments</span>
                <span class="text-[9px] font-bold uppercase">Gelir</span>
            </a>
            <a class="flex flex-col items-center text-slate-400 hover:text-secondary p-2" href="/Expense/Index">
                <span class="material-symbols-outlined mb-1">shopping_cart</span>
                <span class="text-[9px] font-bold uppercase">Gider</span>
            </a>
        }
    </div>
</nav>

    @if (TempData["Success"] != null || TempData["Error"] != null)
    {
        <div id="system-toast" class="fixed top-24 right-4 md:right-8 z-[100] transform transition-all duration-500 translate-x-0">
            @if (TempData["Success"] != null)
            {
                <div class="flex items-center gap-4 bg-white border-l-4 border-emerald-500 p-4 rounded-2xl shadow-xl min-w-[300px]">
                    <div class="w-10 h-10 rounded-full bg-emerald-50 flex items-center justify-center flex-shrink-0"><span class="material-symbols-outlined text-emerald-600">check_circle</span></div>
                    <div><h4 class="text-sm font-bold text-slate-800">İşlem Başarılı</h4><p class="text-xs text-slate-500 font-medium">@TempData["Success"]</p></div>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="flex items-center gap-4 bg-white border-l-4 border-rose-500 p-4 rounded-2xl shadow-xl min-w-[300px]">
                    <div class="w-10 h-10 rounded-full bg-rose-50 flex items-center justify-center flex-shrink-0"><span class="material-symbols-outlined text-rose-600">error</span></div>
                    <div><h4 class="text-sm font-bold text-slate-800">Bir Sorun Oluştu</h4><p class="text-xs text-slate-500 font-medium">@TempData["Error"]</p></div>
                </div>
            }
        </div>

        <script>
            setTimeout(() => {
                const toast = document.getElementById('system-toast');
                if(toast) { toast.classList.add('translate-x-[150%]', 'opacity-0'); setTimeout(() => toast.remove(), 500); }
            }, 4000);
        </script>
    }

    <script>
        document.getElementById('notification-btn').addEventListener('click', function (e) {
            e.stopPropagation(); document.getElementById('notification-dropdown').classList.toggle('hidden');
        });
        document.addEventListener('click', function (e) {
            var container = document.getElementById('notification-container');
            if (!container.contains(e.target)) { document.getElementById('notification-dropdown').classList.add('hidden'); }
        });
    </script>
</body>
</html>