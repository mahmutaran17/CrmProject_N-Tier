@using System.Security.Claims
@inject CrmProject.Business.Abstract.INotificationService NotificationService

<!DOCTYPE html>
<html class="light" lang="tr">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - Executive Ledger</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#00346f",
                        "surface": "#f8f9fa",
                        "on-surface": "#191c1d",
                        "surface-container-highest": "#e1e3e4",
                        // ... (Diğer renkler uzun sürmesin diye kısalttım, Tailwind ana renkleri çalışacaktır)
                    },
                    fontFamily: { "headline": ["Manrope"], "body": ["Inter"] }
                }
            }
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .executive-gradient {
            background: linear-gradient(135deg, #00346f 0%, #004a99 100%);
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8f9fa;
            min-height: max(884px, 100dvh);
        }

        h1, h2, h3, .headline {
            font-family: 'Manrope', sans-serif;
        }
    </style>
</head>
<body class="bg-surface text-on-surface min-h-screen pb-24 md:pb-0 md:pt-16">

    <header class="fixed top-0 w-full z-50 bg-white/80 backdrop-blur-md border-b shadow-sm flex justify-between items-center px-6 py-3">
        <div class="flex items-center gap-3">
            <span class="font-manrope font-extrabold text-blue-900 text-xl tracking-tight">Executive Ledger</span>
        </div>
    
        <div class="hidden md:flex items-center gap-8">
            <nav class="flex gap-6">
                <a class="text-slate-500 hover:text-blue-700 transition-colors font-inter font-semibold text-sm" href="/">Ana Sayfa</a>
                <a class="text-slate-500 hover:text-blue-700 transition-colors font-inter font-semibold text-sm" href="/Project/Index">Projeler</a>
                <a class="text-slate-500 hover:text-blue-700 transition-colors font-inter font-semibold text-sm" href="/AppTask/Index">Görevler</a>
                <a class="text-slate-500 hover:text-blue-700 transition-colors font-inter font-semibold text-sm" href="/User/Index">Personeller</a>
            </nav>
        </div>

        <div class="flex items-center gap-4">
            @if (User.Identity.IsAuthenticated)
            {
                <div class="flex items-center gap-3 pr-4 border-r border-slate-200">
                    <div class="text-right hidden sm:block">
                        <p class="text-xs font-bold text-blue-900 leading-none">@User.Identity.Name</p>
                        <p class="text-[10px] text-slate-500 font-medium">Aktif Kullanıcı</p>
                    </div>
                    <a href="/Login/Logout" class="material-symbols-outlined text-slate-400 hover:text-red-500 transition-colors" title="Çıkış Yap">logout</a>
                </div>
            }
            else
            {
                <a href="/Login/Index" class="text-sm font-bold text-blue-900 hover:underline">Giriş Yap</a>
            }

            @{
                int unreadNotificationCount = 0;
                List<CrmProject.Entity.Entities.Notification> topNotifications = new List<CrmProject.Entity.Entities.Notification>();
    
                if (User.Identity.IsAuthenticated)
                {
                    var userIdStr = User.Claims.FirstOrDefault(c => c.Type == "UserId")?.Value;
                    if (!string.IsNullOrEmpty(userIdStr))
                    {
                        int currentUserId = int.Parse(userIdStr);
                        // Sadece okunmamış bildirimleri veritabanından çekiyoruz
                        var notifications = await NotificationService.GetWhereAsync(n => n.UserId == currentUserId && !n.IsRead);
                        unreadNotificationCount = notifications.Count();
            
                        // Dropdown menüde göstermek için en yeni 5 tanesini alıyoruz
                        topNotifications = notifications.OrderByDescending(n => n.CreatedAt).Take(5).ToList();
                    }
                }
            }

            <div class="relative" id="notification-container">
    
                <div id="notification-btn" class="relative cursor-pointer hover:bg-slate-100 p-2 rounded-xl transition-colors flex items-center justify-center">
                    <span class="material-symbols-outlined text-slate-500">notifications</span>
        
                    @if (unreadNotificationCount > 0)
                    {
                        <span class="absolute top-1 right-1 flex h-4 w-4 items-center justify-center rounded-full bg-red-500 text-[9px] text-white font-black ring-2 ring-white">
                            @unreadNotificationCount
                        </span>
                    }
                </div>

                <div id="notification-dropdown" class="hidden absolute right-0 mt-2 w-80 bg-white rounded-2xl shadow-xl border border-slate-100 z-50 overflow-hidden">
        
                    <div class="p-4 border-b border-slate-50 flex justify-between items-center bg-slate-50">
                        <span class="font-bold text-slate-700 text-sm">Bildirimler</span>
                        @if (unreadNotificationCount > 0)
                        {
                            <a href="/Notification/MarkAllRead" class="text-[11px] text-blue-600 font-bold hover:underline">Tümünü Okundu İşaretle</a>
                        }
                    </div>
        
                    <div class="max-h-80 overflow-y-auto">
                        @if (topNotifications != null && topNotifications.Any())
                        {
                            foreach (var notif in topNotifications)
                            {
                                <a href="/Notification/ReadAndRedirect/@notif.Id" class="block p-4 border-b border-slate-50 hover:bg-blue-50 transition-colors bg-white">
                                    <div class="flex gap-3">
                                        <div class="mt-1 w-2 h-2 rounded-full bg-blue-500 flex-shrink-0"></div>
                                        <div>
                                            <p class="text-xs text-slate-700 font-semibold">@notif.Message</p>
                                            <span class="text-[10px] text-slate-400 mt-1 block">@notif.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                                        </div>
                                    </div>
                                </a>
                            }
                        }
                        else
                        {
                            <div class="p-8 text-center text-slate-500 text-xs font-medium">
                                <span class="material-symbols-outlined text-slate-300 block mb-2 text-3xl">notifications_paused</span>
                                Yeni bildiriminiz yok.
                            </div>
                        }
                    </div>
        
                    <div class="p-3 border-t border-slate-50 text-center bg-slate-50">
                        <a href="/Notification/Index" class="text-xs font-bold text-blue-900 hover:underline">Tüm Bildirimleri Gör</a>
                    </div>
                </div>
            </div>

            <script>
                document.getElementById('notification-btn').addEventListener('click', function() {
                document.getElementById('notification-dropdown').classList.toggle('hidden');
                });

                // Menü dışına tıklanınca kapansın
                document.addEventListener('click', function(event) {
                var container = document.getElementById('notification-container');
                if (!container.contains(event.target)) {
                document.getElementById('notification-dropdown').classList.add('hidden');
                }
                });
            </script>

            <div class="w-8 h-8 rounded-full overflow-hidden bg-gray-200 border border-slate-200">
                <img class="w-full h-full object-cover" src="https://ui-avatars.com/api/?name=@(User.Identity.Name ?? "Misafir")&background=00346f&color=fff" />
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-6 pt-24 pb-12">
        @RenderBody()
    </main>

    <nav class="md:hidden fixed bottom-0 left-0 w-full bg-white/90 backdrop-blur-lg flex justify-around items-center px-4 pb-6 pt-2 z-50 rounded-t-2xl shadow-lg">
        <a class="flex flex-col items-center justify-center text-slate-400 px-4 py-1" href="/">
            <span class="material-symbols-outlined">home</span>
            <span class="text-[11px] font-semibold uppercase tracking-wider mt-1">Ana Sayfa</span>
        </a>
        <a class="flex flex-col items-center justify-center text-blue-900 bg-blue-50 rounded-xl px-4 py-1" href="/Project/Index">
            <span class="material-symbols-outlined">assignment</span>
            <span class="text-[11px] font-semibold uppercase tracking-wider mt-1">Projeler</span>
        </a>
    </nav>

</body>
</html>