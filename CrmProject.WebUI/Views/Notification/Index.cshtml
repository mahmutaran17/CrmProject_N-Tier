@model List<CrmProject.Entity.Entities.Notification>
@{
    ViewData["Title"] = "Tüm Bildirimler";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="flex justify-between items-center mb-8">
    <div>
        <h1 class="text-2xl font-extrabold text-blue-900 tracking-tight">Bildirimlerim</h1>
        <p class="text-sm text-slate-500 mt-1">Sistem tarafından size gönderilen tüm mesajlar.</p>
    </div>
    
    @if (Model.Any(x => !x.IsRead))
    {
        <a href="/Notification/MarkAllRead" class="bg-blue-50 text-blue-700 px-5 py-2.5 rounded-xl text-sm font-semibold flex items-center gap-2 hover:bg-blue-100 transition-colors">
            <span class="material-symbols-outlined text-[20px]">done_all</span> Tümünü Okundu İşaretle
        </a>
    }
</div>

<div class="bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden">
    @if (Model != null && Model.Any())
    {
        <div class="divide-y divide-slate-100">
            @foreach (var item in Model)
            {
                <div class="p-6 flex items-start gap-4 hover:bg-slate-50 transition-colors @(item.IsRead ? "opacity-70" : "")">
                    
                    <div class="mt-1 flex-shrink-0">
                        @if (!item.IsRead)
                        {
                            <span class="flex h-3 w-3 relative">
                                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
                                <span class="relative inline-flex rounded-full h-3 w-3 bg-blue-600"></span>
                            </span>
                        }
                        else
                        {
                            <span class="flex h-3 w-3 rounded-full bg-slate-200"></span>
                        }
                    </div>

                    <div class="flex-1">
                        <p class="text-sm font-bold @(item.IsRead ? "text-slate-600" : "text-slate-900")">
                            @item.Message
                        </p>
                        <span class="text-xs text-slate-400 mt-2 block flex items-center gap-1">
                            <span class="material-symbols-outlined text-[14px]">schedule</span>
                            @item.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                        </span>
                    </div>

                    @if (!item.IsRead)
                    {
                        <a href="/Notification/ReadAndRedirect/@item.Id" class="text-xs font-bold text-blue-600 hover:text-blue-800 bg-blue-50 px-3 py-1.5 rounded-lg border border-blue-100">
                            Görüntüle
                        </a>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div class="p-16 text-center text-slate-500 flex flex-col items-center justify-center">
            <span class="material-symbols-outlined text-6xl text-slate-200 mb-4 block">notifications_off</span>
            <p class="font-bold text-lg">Hiç Bildiriminiz Yok</p>
            <p class="text-sm mt-1">Sistemden gelen uyarılar ve görevler burada listelenir.</p>
        </div>
    }
</div>