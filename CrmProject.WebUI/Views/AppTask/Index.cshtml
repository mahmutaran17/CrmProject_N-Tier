@using CrmProject.Entity.Entities
@model List<CrmProject.Entity.Entities.AppTask>
@{
    ViewData["Title"] = "Görevler";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="flex justify-between items-center mb-8">
    <h1 class="text-2xl font-manrope font-extrabold text-blue-900">Görev Listesi</h1>
    <a href="/AppTask/Create" class="bg-blue-900 text-white px-5 py-2.5 rounded-xl text-sm font-semibold flex items-center gap-2">
        <span class="material-symbols-outlined text-[20px]">add_task</span> Yeni Görev
    </a>
</div>

<div class="bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden">
    <table class="w-full text-left">
        <thead class="bg-slate-50 border-b border-slate-200 text-slate-500 text-xs uppercase">
            <tr>
                <th class="p-4 font-semibold">Görev Başlığı</th>
                <th class="p-4 font-semibold">Bağlı Proje</th>
                <th class="p-4 font-semibold">Son Tarih</th>
                <th class="p-4 font-semibold">Durum</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 text-sm text-slate-700">
            @foreach (var item in Model)
            {
                <tr class="hover:bg-slate-50">
                    <td class="p-4 font-bold text-blue-900">@item.Title</td>
                    <td class="p-4">@(item.Project != null ? item.Project.ProjectName : "-")</td>
                    <td class="p-4">@item.DueDate.ToString("dd.MM.yyyy")</td>
                    <td class="p-4">
                        <span class="px-3 py-1 bg-slate-100 text-slate-800 text-[10px] font-bold uppercase rounded-md">@item.Status</span>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>