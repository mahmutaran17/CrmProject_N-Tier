@using CrmProject.Entity.Entities
@model List<CrmProject.Entity.Entities.AppTask>
@{
    ViewData["Title"] = "Görevler";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="flex justify-between items-center mb-8">
    <h1 class="text-2xl font-manrope font-extrabold text-[#001f48]">Görev Listesi</h1>
    <a href="/AppTask/Create" class="bg-[#00346f] hover:bg-[#001f48] text-white px-5 py-2.5 rounded-xl text-sm font-semibold flex items-center gap-2 transition-colors">
        <span class="material-symbols-outlined text-[20px]">add_task</span> Yeni Görev
    </a>
</div>

<div class="bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden">
    <table class="w-full text-left">
        <thead class="bg-slate-50 border-b border-slate-200 text-slate-500 text-xs uppercase tracking-wider">
            <tr>
                <th class="p-5 font-bold">Görev Başlığı</th>
                <th class="p-5 font-bold">Bağlı Proje</th>
                <th class="p-5 font-bold">Atayan Kişi</th>
                <th class="p-5 font-bold">Son Tarih</th>
                <th class="p-5 font-bold">Durum</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 text-slate-700">
            @foreach (var item in Model)
            {
                <tr class="hover:bg-blue-50/50 cursor-pointer group transition-colors" onclick="window.location='/AppTask/Details/@item.Id';">
                    
                    <td class="p-5 font-extrabold text-[#001f48] group-hover:text-[#0058be] text-base transition-colors">
                        @item.Title
                    </td>
                    
                    <td class="p-5 text-sm font-medium">@(item.Project != null ? item.Project.ProjectName : "-")</td>
                    
                    <td class="p-5 text-sm">@(item.AssignedByUser != null ? $"{item.AssignedByUser.FirstName} {item.AssignedByUser.LastName}" : "Sistem")</td>
                    
                    <td class="p-5 text-sm font-medium">@(item.DueDate.HasValue? item.DueDate.Value.ToString("dd.MM.yyyy") : "Belirtilmedi")</td>
                    
                    <td class="p-5">
                        <span class="px-3 py-1.5 bg-slate-100 text-[#001f48] border border-slate-200 text-[11px] font-bold uppercase tracking-wider rounded-lg">
                            @item.Status
                        </span>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>