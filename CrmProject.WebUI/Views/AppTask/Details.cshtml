@using CrmProject.Entity.Entities
@model CrmProject.Entity.Entities.AppTask
@{
    ViewData["Title"] = "Görev Detayı";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="mb-6 flex items-center justify-between">
    <div class="flex items-center gap-4">
        <a href="/AppTask/Index" class="w-10 h-10 bg-white border border-slate-200 rounded-xl flex items-center justify-center text-slate-500 hover:bg-slate-50 transition-colors">
            <span class="material-symbols-outlined text-[20px]">arrow_back</span>
        </a>
        <div>
            <h1 class="text-2xl font-extrabold text-blue-900 tracking-tight">@Model.Title</h1>
            <p class="text-sm text-slate-500 mt-1">Görev Detayları ve Yönetimi</p>
        </div>
    </div>

    <div class="px-4 py-2 bg-blue-50 border border-blue-100 rounded-xl flex items-center gap-2">
        <span class="material-symbols-outlined text-blue-600 text-[18px]">info</span>
        <span class="text-sm font-bold text-blue-800 uppercase tracking-wider">@Model.Status</span>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    
    <div class="lg:col-span-2 space-y-6">
        
        <div class="bg-white rounded-3xl p-8 border border-slate-200 shadow-sm">
            <h2 class="text-sm font-bold text-slate-400 uppercase tracking-widest mb-4">Görev Açıklaması</h2>
            <div class="text-slate-700 leading-relaxed font-medium bg-slate-50 p-6 rounded-2xl border border-slate-100">
                @(string.IsNullOrWhiteSpace(Model.Description) ? "Bu görev için herhangi bir açıklama girilmemiş." : Model.Description)
            </div>
        </div>

        <div class="bg-white rounded-3xl p-8 border border-slate-200 shadow-sm flex flex-col sm:flex-row gap-8">
            <div class="flex-1">
                <h2 class="text-sm font-bold text-slate-400 uppercase tracking-widest mb-4">Görevi Atayan</h2>
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center text-blue-700 font-bold">
                        @(Model.AssignedByUser != null ? Model.AssignedByUser.FirstName.Substring(0, 1) : "S")
                    </div>
                    <div>
                        <p class="font-bold text-slate-800">@(Model.AssignedByUser != null ? $"{Model.AssignedByUser.FirstName} {Model.AssignedByUser.LastName}" : "Sistem")</p>
                        <p class="text-xs text-slate-500">Yönetici / Atayan</p>
                    </div>
                </div>
            </div>

            <div class="w-px bg-slate-100 hidden sm:block"></div>

            <div class="flex-1">
                <h2 class="text-sm font-bold text-slate-400 uppercase tracking-widest mb-4">Atanan Personeller</h2>
                @if (Model.AssignedUsers != null && Model.AssignedUsers.Any())
                {
                    <div class="flex flex-col gap-3">
                        @foreach (var user in Model.AssignedUsers)
                        {
                            <div class="flex items-center gap-3 bg-slate-50 p-2 rounded-xl border border-slate-100">
                                <span class="material-symbols-outlined text-slate-400">person</span>
                                <span class="text-sm font-bold text-slate-700">@user.FirstName @user.LastName</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-sm font-medium text-slate-500 italic">Kimseye atanmamış.</p>
                }
            </div>
        </div>
    </div>

    <div class="space-y-6">
        
        <div class="bg-white rounded-3xl p-6 border border-slate-200 shadow-sm">
            <ul class="divide-y divide-slate-100">
                <li class="py-3 flex justify-between items-center">
                    <span class="text-sm text-slate-500 font-medium flex items-center gap-2"><span class="material-symbols-outlined text-[18px]">folder</span> Bağlı Proje</span>
                    <span class="text-sm font-bold text-blue-900 bg-blue-50 px-2 py-1 rounded-lg">@(Model.Project != null ? Model.Project.ProjectName : "-")</span>
                </li>
                <li class="py-3 flex justify-between items-center">
                    <span class="text-sm text-slate-500 font-medium flex items-center gap-2"><span class="material-symbols-outlined text-[18px]">calendar_today</span> Başlangıç</span>
                    <span class="text-sm font-bold text-slate-800">@Model.StartDate.ToString("dd.MM.yyyy")</span>
                </li>
                <li class="py-3 flex justify-between items-center">
                    <span class="text-sm text-slate-500 font-medium flex items-center gap-2"><span class="material-symbols-outlined text-[18px]">event_busy</span> Son Teslim</span>
                    <span class="text-sm font-bold @(Model.DueDate.HasValue && Model.DueDate.Value < DateTime.Now && Model.Status != AppTaskStatus.Tamamlandi ? "text-red-600" : "text-slate-800")">
                        @(Model.DueDate.HasValue? Model.DueDate.Value.ToString("dd.MM.yyyy") : "Belirtilmedi")
                    </span>
                </li>
            </ul>
        </div>

        <div class="bg-blue-900 rounded-3xl p-6 shadow-xl shadow-blue-200 text-white">
            <h2 class="text-lg font-bold mb-4 flex items-center gap-2">
                <span class="material-symbols-outlined">update</span> Durumu Güncelle
            </h2>
            
            <form action="/AppTask/UpdateStatus" method="post" class="space-y-4">
                <input type="hidden" name="id" value="@Model.Id" />
                
                <select name="status" class="w-full bg-white/10 border-white/20 text-white rounded-xl py-3 focus:ring-white focus:border-white [&>option]:text-slate-900">
                    @foreach (var status in Enum.GetValues(typeof(AppTaskStatus)).Cast<AppTaskStatus>())
                    {
                        if (Model.Status == status)
                        {
                            <option value="@status" selected>@status.ToString()</option>
                        }
                        else
                        {
                            <option value="@status">@status.ToString()</option>
                        }
                    }
                </select>

                <button type="submit" class="w-full bg-white text-blue-900 font-bold py-3 rounded-xl hover:bg-slate-100 transition-colors flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-[20px]">save</span> Kaydet
                </button>
            </form>
        </div>

    </div>
</div>