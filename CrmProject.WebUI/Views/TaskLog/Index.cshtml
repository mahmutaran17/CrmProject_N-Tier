@model List<CrmProject.Entity.Entities.TaskLog>
@{
    ViewData["Title"] = "Görev Günlükleri";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="flex justify-between items-center mb-8">
    <h1 class="text-2xl font-bold text-blue-900">Görev Günlükleri (Loglar)</h1>
    <a href="/TaskLog/Create" class="bg-blue-900 text-white px-5 py-2.5 rounded-xl text-sm font-semibold">Yeni Not Ekle</a>
</div>

<div class="bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden">
    <table class="w-full text-left">
        <thead class="bg-slate-50 border-b border-slate-200 text-slate-500 text-xs uppercase">
            <tr>
                <th class="p-4 font-semibold">Tarih</th>
                <th class="p-4 font-semibold">Görev</th>
                <th class="p-4 font-semibold">Açıklama</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 text-sm text-slate-700">
            @foreach (var item in Model)
            {
                <tr class="hover:bg-slate-50">
                    <td class="p-4 whitespace-nowrap">@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                    <td class="p-4 font-bold text-blue-900">@(item.TaskItem != null ? item.TaskItem.Title : "-")</td>
                    <td class="p-4 text-slate-500">@item.Description</td>
                </tr>
            }
        </tbody>
    </table>
</div>