@model CrmProject.Entity.Entities.TaskLog
@{
    ViewData["Title"] = "Yeni Günlük Ekle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="mb-8">
    <h1 class="text-2xl font-bold text-blue-900">Göreve Günlük/Not Ekle</h1>
</div>

<div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8 max-w-4xl">
    <form method="post" action="/TaskLog/Create">
        
        <div class="grid grid-cols-1 gap-6">
            
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">İlgili Görev <span class="text-red-500">*</span></label>
                <select asp-for="TaskItemId" asp-items="ViewBag.Tasks" class="w-full rounded-xl border-slate-300 py-2.5 text-sm" required>
                    <option value="">-- Görev Seçiniz --</option>
                </select>
            </div>

            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Yapılan İşlem / Not <span class="text-red-500">*</span></label>
                <textarea asp-for="Description" rows="4" class="w-full rounded-xl border-slate-300 py-2.5 text-sm" placeholder="Bu görev için neler yapıldı?" required></textarea>
            </div>

        </div>

        <div class="mt-8 flex justify-end gap-3 pt-6 border-t border-slate-100">
            <a href="/TaskLog/Index" class="px-5 py-2.5 text-sm font-semibold text-slate-600 bg-slate-100 rounded-xl">Vazgeç</a>
            <button type="submit" class="px-5 py-2.5 text-sm font-semibold text-white bg-blue-900 rounded-xl">Kaydet</button>
        </div>
    </form>
</div>