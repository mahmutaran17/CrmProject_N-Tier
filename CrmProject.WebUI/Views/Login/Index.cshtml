@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Executive Ledger | Giriş</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 flex items-center justify-center min-h-screen font-inter">
    <div class="bg-white p-10 rounded-3xl shadow-xl w-full max-w-md border border-slate-100">
        <div class="text-center mb-10">
            <h1 class="text-3xl font-black text-[#001f48] tracking-tighter">Executive Ledger</h1>
            <p class="text-slate-500 mt-2 text-sm font-medium">Lütfen hesabınıza giriş yapın.</p>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="bg-rose-50 text-rose-600 p-4 rounded-xl text-xs mb-6 border border-rose-100 font-bold">
                @TempData["Error"]
            </div>
        }

        @if (TempData["Success"] != null)
        {
            <div class="bg-emerald-50 text-emerald-600 p-4 rounded-xl text-xs mb-6 border border-emerald-100 font-bold">
                @TempData["Success"]
            </div>
        }

        <form action="/Login/Index?ReturnUrl=@ViewBag.ReturnUrl" method="post" class="space-y-5">
            <div>
                <label class="block text-xs font-bold text-slate-700 uppercase mb-2">E-Posta</label>
                <input type="email" name="email" required class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-[#0058be] outline-none transition-all">
            </div>
            <div>
                <label class="block text-xs font-bold text-slate-700 uppercase mb-2">Şifre</label>
                <input type="password" name="password" required class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-[#0058be] outline-none transition-all">
            </div>
            <button type="submit" class="w-full bg-[#00346f] hover:bg-[#001f48] text-white font-bold py-3.5 rounded-xl shadow-lg transition-all active:scale-95">Giriş Yap</button>
        </form>
    </div>
</body>
</html>