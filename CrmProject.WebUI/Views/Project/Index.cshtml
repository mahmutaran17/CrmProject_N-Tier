@using CrmProject.Entity.Entities
@model List<CrmProject.Entity.Entities.Project>

@{
    ViewData["Title"] = "Projeler";
}

<section class="mb-8 mt-4">
    <div class="relative group">
        <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none">
            <span class="material-symbols-outlined text-outline">search</span>
        </div>
        <input class="w-full bg-surface-container-low border-none border-b-2 border-outline/20 focus:border-primary focus:ring-0 py-4 pl-12 pr-4 font-body text-on-surface placeholder:text-outline/60 transition-all rounded-xl" placeholder="Projelerde ara..." type="text" />
    </div>
</section>

<div class="space-y-6">
    <h2 class="font-headline font-bold text-2xl text-primary mb-2">Aktif Portföyler</h2>

    @foreach (var item in Model)
    {
        <div class="bg-surface-container-lowest p-6 rounded-xl editorial-shadow group transition-all hover:bg-surface-bright">

            <div class="flex justify-between items-start mb-4">
                <div>
                    <span class="text-[10px] font-bold uppercase tracking-widest text-outline mb-1 block">@item.Description</span>
                    <h3 class="font-headline font-bold text-lg text-on-surface group-hover:text-primary transition-colors leading-tight">@item.ProjectName</h3>
                </div>

                @if (item.Status == ProjectStatus.Aktif)
                {
                    <span class="px-3 py-1 bg-green-100 text-green-800 border border-green-200 text-[10px] font-bold uppercase tracking-wider rounded-md">Aktif</span>
                }
                else if (item.Status == ProjectStatus.Beklemede)
                {
                    <span class="px-3 py-1 bg-orange-100 text-orange-800 border border-orange-200 text-[10px] font-bold uppercase tracking-wider rounded-md">Beklemede</span>
                }
                else
                {
                    <span class="px-3 py-1 bg-red-100 text-red-800 border border-red-200 text-[10px] font-bold uppercase tracking-wider rounded-md">@item.Status</span>
                }
            </div>

            <div class="mt-4 flex items-center gap-4 text-xs font-medium text-on-surface-variant bg-surface-container-low p-2 rounded-lg inline-flex">
                <span class="flex items-center gap-1" title="Başlangıç Tarihi">
                    <span class="material-symbols-outlined text-[14px]">calendar_today</span>
                    @item.StartDate.ToString("dd.MM.yyyy")
                </span>
                <span class="text-outline">|</span>
                <span class="flex items-center gap-1" title="Bitiş Tarihi">
                    <span class="material-symbols-outlined text-[14px]">event_available</span>
                    @(item.EndDate.HasValue? item.EndDate.Value.ToString("dd.MM.yyyy") : "Belirtilmedi")
                </span>
            </div>

            <div class="mt-6 flex items-center justify-end gap-3 border-t border-outline/5 pt-4">
                <a href="/Project/UpdateProject/@item.Id" class="flex items-center gap-1 text-xs font-bold text-yellow-600 hover:text-yellow-700 transition-colors">
                    <span class="material-symbols-outlined text-[16px]">edit</span> Düzenle
                </a>
                <a href="/Project/DeleteProject/@item.Id" class="flex items-center gap-1 text-xs font-bold text-red-600 hover:text-red-700 transition-colors">
                    <span class="material-symbols-outlined text-[16px]">delete</span> Sil
                </a>
            </div>
        </div>
    }
</div>

<a href="/Project/AddProject" class="fixed bottom-24 right-6 w-14 h-14 rounded-full bg-gradient-to-br from-primary to-primary-container text-white shadow-xl flex items-center justify-center active:scale-90 transition-transform z-[60]">
    <span class="material-symbols-outlined text-3xl">add</span>
</a>