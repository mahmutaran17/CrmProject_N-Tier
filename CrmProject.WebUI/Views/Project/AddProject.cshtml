@model CrmProject.Entity.Entities.Project
@{
    ViewData["Title"] = "Yeni Proje Ekle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="mb-8">
    <h1 class="text-2xl font-manrope font-extrabold text-blue-900 tracking-tight">Yeni Proje Ekle</h1>
</div>

<div class="bg-white rounded-3xl shadow-sm border border-slate-200 p-8 max-w-4xl">
    <form method="post" action="/Project/AddProject">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 font-inter">

            <div class="md:col-span-2">
                <label class="block text-sm font-semibold text-slate-700 mb-2">Müşteri (Cari) Seçin <span class="text-red-500">*</span></label>
                <select asp-for="CustomerId" class="w-full rounded-xl border-slate-300 focus:border-blue-600 focus:ring focus:ring-blue-200 text-sm py-2.5" required>
                    <option value="">-- Müşteri Seçiniz --</option>
                    @if (ViewBag.Customers != null)
                    {
                        foreach (var item in ViewBag.Customers as List<CrmProject.Entity.Entities.Customer>)
                        {
                            <option value="@item.Id">@item.CustomerName</option>
                        }
                    }
                </select>
            </div>

            <div class="md:col-span-2">
                <label class="block text-sm font-semibold text-slate-700 mb-2">Proje Adı <span class="text-red-500">*</span></label>
                <input type="text" asp-for="ProjectName" class="w-full rounded-xl border-slate-300 focus:border-blue-600 focus:ring focus:ring-blue-200 text-sm py-2.5" required />
            </div>

            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Başlangıç Tarihi <span class="text-red-500">*</span></label>
                <input type="date" asp-for="StartDate" class="w-full rounded-xl border-slate-300 focus:border-blue-600 focus:ring focus:ring-blue-200 text-sm py-2.5" required />
            </div>

            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Bitiş Tarihi</label>
                <input type="date" asp-for="EndDate" class="w-full rounded-xl border-slate-300 focus:border-blue-600 focus:ring focus:ring-blue-200 text-sm py-2.5" />
            </div>

            <div class="md:col-span-2">
                <label class="block text-sm font-semibold text-slate-700 mb-2">Proje Detayları</label>
                <textarea asp-for="Description" rows="4" class="w-full rounded-xl border-slate-300 focus:border-blue-600 focus:ring focus:ring-blue-200 text-sm py-2.5"></textarea>
            </div>

        </div>

        <div class="mt-8 flex justify-end gap-3 border-t border-slate-100 pt-6">
            <a href="/Project/Index" class="px-5 py-2.5 text-sm font-semibold text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-xl">Vazgeç</a>
            <button type="submit" class="px-5 py-2.5 text-sm font-semibold text-white bg-blue-900 hover:bg-blue-800 rounded-xl">Kaydet</button>
        </div>
    </form>
</div>