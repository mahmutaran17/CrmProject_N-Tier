@model CrmProject.Entity.Entities.Project

@{
    ViewData["Title"] = "Yeni Proje Ekle";
}

<div class="max-w-3xl mx-auto">

    <div class="flex items-center justify-between mb-8">
        <h2 class="font-headline font-bold text-2xl text-primary">Yeni Proje Oluştur</h2>
        <a href="/Project/Index" class="flex items-center gap-1 text-sm font-bold text-outline hover:text-primary transition-colors">
            <span class="material-symbols-outlined text-[18px]">arrow_back</span> Listeye Dön
        </a>
    </div>

    <div class="bg-surface-container-lowest p-8 rounded-2xl editorial-shadow">
        <form asp-controller="Project" asp-action="AddProject" method="post" class="space-y-6">

            <div>
                <label class="block text-[11px] font-bold uppercase tracking-widest text-outline mb-2">Proje Adı</label>
                <input type="text" asp-for="ProjectName" class="w-full bg-surface-container-low border-none border-b-2 border-outline/20 focus:border-primary focus:ring-0 py-3 px-4 font-body text-on-surface rounded-t-xl transition-all" required placeholder="Örn: Q4 Pazarlama Kampanyası" />
            </div>

            <div>
                <label class="block text-[11px] font-bold uppercase tracking-widest text-outline mb-2">Proje Açıklaması</label>
                <textarea asp-for="Description" rows="4" class="w-full bg-surface-container-low border-none border-b-2 border-outline/20 focus:border-primary focus:ring-0 py-3 px-4 font-body text-on-surface rounded-t-xl transition-all" placeholder="Projenin detaylarını buraya yazın..."></textarea>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-[11px] font-bold uppercase tracking-widest text-outline mb-2">Başlangıç Tarihi</label>
                    <input type="date" asp-for="StartDate" class="w-full bg-surface-container-low border-none border-b-2 border-outline/20 focus:border-primary focus:ring-0 py-3 px-4 font-body text-on-surface rounded-t-xl transition-all text-sm" required />
                </div>
                <div>
                    <label class="block text-[11px] font-bold uppercase tracking-widest text-outline mb-2">Bitiş/Teslim Tarihi</label>
                    <input type="date" asp-for="EndDate" class="w-full bg-surface-container-low border-none border-b-2 border-outline/20 focus:border-primary focus:ring-0 py-3 px-4 font-body text-on-surface rounded-t-xl transition-all text-sm" required />
                </div>
            </div>

            <div class="pt-6 border-t border-outline/10 flex justify-end gap-4 mt-8">
                <a href="/Project/Index" class="px-6 py-3 rounded-xl font-bold text-on-surface-variant bg-surface-container-high hover:bg-surface-variant transition-colors">İptal</a>
                <button type="submit" class="px-6 py-3 rounded-xl font-bold text-white bg-gradient-to-r from-primary to-primary-container shadow-lg hover:scale-105 active:scale-95 transition-all flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">save</span> Kaydet
                </button>
            </div>

        </form>
    </div>
</div>