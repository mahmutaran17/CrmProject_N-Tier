@using CrmProject.Entity.Entities
@model CrmProject.Entity.Entities.Project
@{
    ViewData["Title"] = "Proje Güncelle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="max-w-3xl mx-auto">
    <div class="mb-8">
        <h1 class="text-2xl font-extrabold text-[#001f48] tracking-tight">Proje Güncelle</h1>
        <p class="text-sm text-slate-500 mt-1">@Model.ProjectName detaylarını düzenliyorsunuz.</p>
    </div>

    <div class="bg-white rounded-3xl p-8 shadow-sm border border-slate-200">
        <form action="/Project/UpdateProject" method="post" class="space-y-6">
            <input type="hidden" name="Id" value="@Model.Id" />
            
            <input type="hidden" name="CustomerId" value="@Model.CustomerId" />

            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">Proje Adı</label>
                <input type="text" name="ProjectName" value="@Model.ProjectName" required class="w-full bg-slate-50 border border-slate-200 text-slate-900 rounded-xl px-4 py-3 focus:ring-[#0058be] focus:border-[#0058be]" />
            </div>

            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">Proje Açıklaması</label>
                <textarea name="Description" rows="3" class="w-full bg-slate-50 border border-slate-200 text-slate-900 rounded-xl px-4 py-3 focus:ring-[#0058be] focus:border-[#0058be]">@Model.Description</textarea>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Başlangıç Tarihi</label>
                    <input type="date" name="StartDate" value="@Model.StartDate.ToString("yyyy-MM-dd")" required class="w-full bg-slate-50 border border-slate-200 text-slate-900 rounded-xl px-4 py-3 focus:ring-[#0058be] focus:border-[#0058be]" />
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Bitiş Tarihi</label>
                    <input type="date" name="EndDate" value="@(Model.EndDate.HasValue? Model.EndDate.Value.ToString("yyyy-MM-dd") : "")" class="w-full bg-slate-50 border border-slate-200 text-slate-900 rounded-xl px-4 py-3 focus:ring-[#0058be] focus:border-[#0058be]" />
                </div>
            </div>

            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">Proje Durumu</label>
                <select name="Status" class="w-full bg-slate-50 border border-slate-200 text-slate-900 rounded-xl px-4 py-3 focus:ring-[#0058be] focus:border-[#0058be]">
                    <option value="Aktif" selected="@(Model.Status == ProjectStatus.Aktif)">Aktif</option>
                    <option value="Beklemede" selected="@(Model.Status == ProjectStatus.Beklemede)">Beklemede</option>
                    <option value="Tamamlandi" selected="@(Model.Status == ProjectStatus.Tamamlandi)">Tamamlandı</option>
                    
                    @if (User.IsInRole("Admin"))
                    {
                        <option value="Silindi" selected="@(Model.Status == ProjectStatus.Silindi)">İptal / Silindi</option>
                    }
                </select>
            </div>

            <div class="pt-4 border-t border-slate-100 flex justify-end gap-3">
                <a href="/Project/Index" class="px-6 py-3 text-slate-600 font-bold bg-slate-100 hover:bg-slate-200 rounded-xl transition-colors">İptal</a>
                <button type="submit" class="px-6 py-3 bg-[#00346f] hover:bg-[#001f48] text-white font-bold rounded-xl transition-colors">Değişiklikleri Kaydet</button>
            </div>
        </form>
    </div>
</div>